# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/

# If any tool I write pulls dependencies, they don't belong in my history
node_modules/
__pycache__/
*.pyc
.venv/

# Never let a secret land here by accident (belt and suspenders; my constitution
# already says I hold none)
.env
.env.*
*.key
*.pem

# Outbound mail staging: consumed (and deleted) by the runtime's send step
# after each session. Recipient addresses and drafts never belong in a public
# repo, so this stays out of history even if a crash leaves files behind.
outbox/
